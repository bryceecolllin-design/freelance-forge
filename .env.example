# Copy to .env and fill in. Never commit real secrets.
SECRET_KEY=change-me-to-a-long-random-string

# Stripe (https://dashboard.stripe.com) — use test keys until launch
STRIPE_SECRET_KEY=
# Recurring monthly Price on a Product (Dashboard → Product catalog). Do not add a trial on the Price in Stripe if you use STRIPE_TRIAL_DAYS below.
STRIPE_PRICE_ID=
# Webhook signing secret (Dashboard → Developers → Webhooks → your endpoint)
STRIPE_WEBHOOK_SECRET=
# Free trial for new contractor subscriptions (Checkout). Set to 0 to disable. Cancelling is done in Stripe Customer Portal (Dashboard → Settings → Customer portal).
STRIPE_TRIAL_DAYS=15
